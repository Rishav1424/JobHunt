{
  "manifest_version": 3,
  "name": "JobHunt Copilot",
  "version": "1.0.0",
  "description": "Stateful autofill assistant and PDF resume tailor for JobHunt.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "sidePanel",
    "identity"
  ],
  "host_permissions": [
    "http://localhost:4000/*"
  ],
  "oauth2": {
    "client_id": "YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly"
    ]
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": ["src/content.ts"],
      "matches": [
        "https://jobs.lever.co/*",
        "https://boards.greenhouse.io/*",
        "https://*.myworkdayjobs.com/*",
        "https://app.ashbyhq.com/*",
        "https://wellfound.com/*",
        "https://angel.co/*",
        "https://www.instahyre.com/*",
        "https://careers.smartrecruiters.com/*",
        "https://*.icims.com/*",
        "https://*.taleo.net/*",
        "https://www.naukri.com/*",
        "https://*.hire.trakstar.com/*",
        "https://jobs.ashbyhq.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open JobHunt Copilot"
  }
}
