# ─── Required ────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Job APIs ────────────────────────────────────────────────────────────────
# Free registration at: https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# Optional: ~$10/mo for Google Jobs search (2500 free requests)
# Register at: https://serper.dev
SERPER_API_KEY=

# ─── Auth ────────────────────────────────────────────────────────────────────
# Dashboard login password (single-user system)
DASHBOARD_PASSWORD=change_this_password

# Secret for JWT tokens (run: openssl rand -hex 32)
JWT_SECRET=change_this_to_a_random_secret_string

# ─── Database (auto-filled by docker-compose) ─────────────────────────────────
# For standalone deployment, point this to your active PostgreSQL instance.
DATABASE_URL=postgresql://jobhunt:jobhunt_secret@localhost:5432/jobhunt

# ─── Redis (auto-filled by docker-compose) ────────────────────────────────────
# For standalone deployment, point this to your active Redis instance.
REDIS_URL=redis://localhost:6379

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
STORAGE_PATH=./storage

# ─── Gmail (Optional — Phase 5: Email Tracking) ───────────────────────────────
# See docs for OAuth2 setup: https://developers.google.com/gmail/api
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
